rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - displayName: string (required)
    //   - avatarUrl: string (optional)
    //   - totalCoins: number (required, >= 0)
    //   - stats: map (required)
    //     - wins: number
    //     - totalPoints: number
    //     - gamesPlayed: number
    //   - inventory: map (optional)
    //   - lastActive: timestamp (required)
    //   - role: string (optional, enum: ['user', 'admin'])
    //
    // Collection: rooms
    // Document ID: {roomId}
    // Fields:
    //   - name: string (required)
    //   - status: string (required, enum: ['waiting', 'playing', 'finished'])
    //   - mode: string (required, enum: ['classic', 'theme', 'speed'])
    //   - currentRound: number (required)
    //   - totalRounds: number (required)
    //   - currentDrawerId: string (optional)
    //   - currentWord: string (optional)
    //   - timeLeft: number (required)
    //   - createdAt: timestamp (required)
    //   - lastActive: timestamp (required)
    //   - hostId: string (required)
    //   - isQuickPlay: bool (optional)
    //
    // Sub-collection: rooms/{roomId}/players
    // Document ID: {playerId}
    // Fields:
    //   - name: string (required)
    //   - avatarUrl: string (optional)
    //   - score: number (required)
    //   - coins: number (required)
    //   - isReady: bool (required)
    //   - isHost: bool (required)
    //   - lastActive: string (required, ISO 8601)
    //   - isBot: bool (optional)
    //   - hasGuessedCorrectly: bool (optional)
    //
    // Sub-collection: rooms/{roomId}/messages
    // Document ID: {messageId}
    // Fields:
    //   - senderId: string (required)
    //   - senderName: string (required)
    //   - text: string (required)
    //   - type: string (required, enum: ['chat', 'system', 'guess'])
    //   - createdAt: timestamp (required)
    //
    // Document: rooms/{roomId}/drawing/current
    // Fields:
    //   - lines: string (required, JSON stringified array)
    //   - updatedAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin' ||
          (request.auth.token.email == "nawinrajpandiarajan@gmail.com" && request.auth.token.email_verified == true));
    }

    function isPlayerInRoom(roomId) {
      return isAuthenticated() && exists(/databases/$(database)/documents/rooms/$(roomId)/players/$(request.auth.uid));
    }

    function isHost(roomId) {
      return isAuthenticated() && get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId == request.auth.uid;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isRecent(time) {
      return time is timestamp && time > request.time - duration.value(5, 'm') && time < request.time + duration.value(5, 'm');
    }

    function isValidUser(data) {
      return hasOnlyAllowedFields(['displayName', 'avatarUrl', 'totalCoins', 'stats', 'inventory', 'lastActive', 'role']) &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 50 &&
             (!('avatarUrl' in data) || (data.avatarUrl is string && data.avatarUrl.size() < 500) || data.avatarUrl == null) &&
             data.totalCoins is number && data.totalCoins >= 0 &&
             (data.stats is map && 
              data.stats.wins is number && 
              data.stats.totalPoints is number && 
              data.stats.gamesPlayed is number) &&
             (!('inventory' in data) || data.inventory is map) &&
             (data.lastActive is timestamp || data.lastActive == null) &&
             (!('role' in data) || data.role in ['user', 'admin']);
    }

    function isValidRoom(data) {
      return hasOnlyAllowedFields(['name', 'status', 'mode', 'currentRound', 'totalRounds', 'currentDrawerId', 'currentWord', 'timeLeft', 'createdAt', 'lastActive', 'isQuickPlay', 'hostId']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.status in ['waiting', 'playing', 'finished'] &&
             data.mode in ['classic', 'theme', 'speed'] &&
             data.currentRound is number &&
             data.totalRounds is number &&
             data.timeLeft is number &&
             (data.createdAt is timestamp || data.createdAt == null) &&
             (data.lastActive is timestamp || data.lastActive == null) &&
             data.hostId is string &&
             (!('isQuickPlay' in data) || data.isQuickPlay is bool);
    }

    function isValidPlayer(data) {
      return hasOnlyAllowedFields(['name', 'avatarUrl', 'score', 'coins', 'isReady', 'isHost', 'lastActive', 'isBot', 'hasGuessedCorrectly']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 50 &&
             (!('avatarUrl' in data) || (data.avatarUrl is string && data.avatarUrl.size() < 500) || data.avatarUrl == null) &&
             data.score is number &&
             data.coins is number &&
             data.isReady is bool &&
             data.isHost is bool &&
             (!('lastActive' in data) || (data.lastActive is string && data.lastActive.size() < 100)) &&
             (!('isBot' in data) || data.isBot is bool) &&
             (!('hasGuessedCorrectly' in data) || data.hasGuessedCorrectly is bool);
    }

    function isValidMessage(data) {
      return hasOnlyAllowedFields(['senderId', 'senderName', 'text', 'type', 'createdAt']) &&
             data.senderId is string && data.senderId.size() < 100 &&
             data.senderName is string && data.senderName.size() > 0 && data.senderName.size() < 50 &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000 &&
             data.type in ['chat', 'system', 'guess'] &&
             data.createdAt is timestamp;
    }

    // Test collection for connection check
    match /test/{docId} {
      allow read: if isAuthenticated();
    }

    // User rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.get('role', 'user') == 'user';
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.get('role', 'user') == resource.data.get('role', 'user')) || isAdmin();
    }

    // Room rules
    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRoom(request.resource.data) && request.resource.data.hostId == request.auth.uid;
      allow update: if isAuthenticated() && isValidRoom(request.resource.data) && (isHost(roomId) || isPlayerInRoom(roomId));
      
      match /players/{playerId} {
        allow read: if isAuthenticated();
        // Allow user to create their own player doc, or host to manage bots
        allow create: if isAuthenticated() && (request.auth.uid == playerId || (isHost(roomId) && request.resource.data.get('isBot', false) == true)) && isValidPlayer(request.resource.data);
        allow update: if isAuthenticated() && (request.auth.uid == playerId || isHost(roomId) || isPlayerInRoom(roomId)) && isValidPlayer(request.resource.data);
      }
      
      match /messages/{messageId} {
        allow read: if isPlayerInRoom(roomId);
        allow create: if isPlayerInRoom(roomId) && isValidMessage(request.resource.data) && (
          request.resource.data.senderId == request.auth.uid || 
          request.resource.data.senderId == 'system' ||
          (isHost(roomId) && get(/databases/$(database)/documents/rooms/$(roomId)/players/$(request.resource.data.senderId)).data.isBot == true)
        );
      }
      
      match /drawing/current {
        allow read: if isPlayerInRoom(roomId);
        allow write: if isPlayerInRoom(roomId);
      }
    }
  }
}
